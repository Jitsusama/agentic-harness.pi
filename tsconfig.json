{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"paths": {
			"@mariozechner/pi-coding-agent": [
				"./node_modules/@earendil-works/pi-coding-agent"
			],
			"@mariozechner/pi-coding-agent/*": [
				"./node_modules/@earendil-works/pi-coding-agent/*"
			],
			"@mariozechner/pi-tui": ["./node_modules/@earendil-works/pi-tui"],
			"@mariozechner/pi-tui/*": ["./node_modules/@earendil-works/pi-tui/*"],
			"@mariozechner/pi-ai": ["./node_modules/@earendil-works/pi-ai"],
			"@mariozechner/pi-ai/*": ["./node_modules/@earendil-works/pi-ai/*"],
			"@sinclair/typebox": ["./node_modules/typebox"],
			"@sinclair/typebox/value": [
				"./node_modules/typebox/build/value/index.d.mts"
			],
			"@sinclair/typebox/compile": [
				"./node_modules/typebox/build/compile/index.d.mts"
			],
			"@sinclair/typebox/*": ["./node_modules/typebox/*"]
		}
	},
	"include": ["extensions/**/*.ts", "lib/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist", ".pi", ".worktrees"]
}
