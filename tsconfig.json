{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"@mariozechner/pi-coding-agent": [
				"node_modules/@earendil-works/pi-coding-agent"
			],
			"@mariozechner/pi-coding-agent/*": [
				"node_modules/@earendil-works/pi-coding-agent/*"
			],
			"@mariozechner/pi-tui": ["node_modules/@earendil-works/pi-tui"],
			"@mariozechner/pi-tui/*": ["node_modules/@earendil-works/pi-tui/*"],
			"@mariozechner/pi-ai": ["node_modules/@earendil-works/pi-ai"],
			"@mariozechner/pi-ai/*": ["node_modules/@earendil-works/pi-ai/*"],
			"@sinclair/typebox": ["node_modules/typebox"],
			"@sinclair/typebox/value": ["node_modules/typebox/build/value"],
			"@sinclair/typebox/value/*": ["node_modules/typebox/build/value/*"],
			"@sinclair/typebox/*": ["node_modules/typebox/*"]
		}
	},
	"include": ["extensions/**/*.ts", "lib/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist", ".pi", ".worktrees"]
}
