{
	"name": "agentic-harness.pi",
	"version": "0.1.0",
	"description": "Collaborative coding workflows for pi: planning, TDD, git hygiene, and code investigation.",
	"keywords": [
		"pi-package"
	],
	"license": "MIT",
	"exports": {
		"./guardian": "./lib/guardian/index.ts",
		"./shell": "./lib/shell/index.ts",
		"./ui": "./lib/ui/index.ts",
		"./slack": "./lib/slack/index.ts",
		"./slack/api": "./lib/slack/api/index.ts",
		"./slack/auth": "./lib/slack/auth/index.ts",
		"./slack/renderers": "./lib/slack/renderers/index.ts",
		"./slack/resolvers": "./lib/slack/resolvers/index.ts",
		"./google": "./lib/google/index.ts",
		"./google/apis": "./lib/google/apis/index.ts",
		"./google/auth": "./lib/google/auth/index.ts",
		"./google/renderers": "./lib/google/renderers/index.ts",
		"./web": "./lib/web/index.ts",
		"./subagent": "./lib/subagent/index.ts",
		"./refs": "./lib/refs/index.ts",
		"./people": "./lib/people/index.ts",
		"./terminal": "./lib/terminal/index.ts",
		"./quest": "./lib/quest/index.ts",
		"./tree": "./lib/tree/index.ts",
		"./mcp": "./lib/mcp/index.ts"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"typecheck:full": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@9.15.0",
	"pi": {
		"extensions": [
			"./extensions"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"defuddle": "^0.19.1",
		"google-auth-library": "^9.14.2",
		"googleapis": "^140.0.1",
		"jsdom": "^28.1.0",
		"jsonpath-plus": "^10.4.0",
		"puppeteer-core": "^24.38.0",
		"sqlite3": "^5.1.7",
		"vscode-jsonrpc": "^9.0.1",
		"vscode-languageserver-protocol": "^3.18.2",
		"yaml": "^2.9.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-ai": "^0.75.0",
		"@earendil-works/pi-coding-agent": "^0.75.0",
		"@earendil-works/pi-tui": "^0.75.0",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"typebox": "^1.3.6",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
